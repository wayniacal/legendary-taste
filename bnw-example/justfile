# bnw: Brave New Word. Copy these files into sites/b0y-eu/bnw/ to adopt.

default: check

# Oracle: JSDoc-level typecheck (no TS conversion, no build step) + id contract.
# typescript is pinned to an EXACT version: `@6` still re-resolves to the latest
# 6.x every run, and a tsc minor bump changes diagnostics, so the gate would fail
# on code nobody touched. This lane has no lockfile by design (zero deps, copy to
# adopt); tsc has no transitive deps, so an exact pin is the whole supply chain.
# Bump deliberately. See README "Rules that aren't files".
check: check-ids
    npx -y -p typescript@6.0.3 tsc -p jsconfig.json

# The ids passed to $() in app.js are the contract with index.html.
# tsc can't see this (getElementById types the same for any string), so grep is the checker.
check-ids:
    #!/usr/bin/env bash
    set -euo pipefail
    fail=0
    for id in $(grep -oE "\\\$\('[A-Za-z0-9-]+'\)" app.js | sed "s/^..'//; s/')$//" | sort -u); do
        grep -q "id=\"$id\"" index.html || { echo "app.js uses \$('$id') but index.html has no id=\"$id\"" >&2; fail=1; }
    done
    exit $fail

# Caddy serves precompressed .br/.gz siblings. Editing a source file without
# regenerating them serves the STALE compressed copy, silently. Run after every edit.
build:
    #!/usr/bin/env bash
    set -euo pipefail
    for f in index.html app.js style.css corpora/*.txt; do
        if [ ! -f "$f.br" ] || [ "$f" -nt "$f.br" ]; then
            brotli -f -k "$f"
            gzip -f -k -9 "$f"
            echo "recompressed $f"
        fi
    done

# Serve locally. wasm requires http(s), file:// won't work.
run:
    python3 -m http.server 8090

# No auto-fixers for hand-written vanilla JS; tsc findings are fixed by hand.
fix:
    @echo "no auto-fixers for this lane; fix tsc findings by hand" >&2; exit 1

# No behavior suite; the typecheck + id contract is the whole oracle.
test: check

# Copy into the live root, then prove the deploy landed: fetch the URL and
# grep a sentinel. A printed URL is hope; a fetched one is verification.
ship: check build
    cp -p index.html app.js style.css *.br *.gz "$HOME/sites/b0y-eu/bnw/"
    cp -p corpora/*.txt corpora/*.br corpora/*.gz "$HOME/sites/b0y-eu/bnw/corpora/"
    curl -sf https://b0y.eu/bnw/ | grep -q "Brave New Word"
    @echo "live: https://b0y.eu/bnw/"

save msg="checkpoint":
    jj commit -m "{{msg}}"
    jj bookmark set main -r @-
    -jj git push --remote origin -b main
