{
  "permissions": {
    "allow": [
      "Bash(just:*)",
      "Bash(jj:*)",
      "Bash(mise:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(npx tsc:*)",
      "Bash(pnpm test:*)",
      "Bash(uv run pyright:*)",
      "Bash(uv run pytest:*)",
      "Bash(ruff:*)",
      "Bash(biome:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && export PATH=\"$HOME/.local/share/mise/shims:$PATH\" && out=$(just check 2>&1) || { echo \"$out\" >&2; exit 2; }"
          }
        ]
      }
    ]
  }
}
